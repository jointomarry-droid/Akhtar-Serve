# Firebase Configuration (Client-Side)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:000000000000000000
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin SDK (Server-Side) - For production
# Option 1: Service account JSON (escape newlines as \n)
# FIREBASE_ADMIN_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project",...}

# Option 2: Individual credentials
# FIREBASE_ADMIN_PROJECT_ID=your-project-id
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Emulators (Development)
NEXT_PUBLIC_USE_EMULATORS=false

# ==================== POCKETBASE CONFIGURATION ====================

# PocketBase Server URL (Client-Side)
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090

# PocketBase Admin Credentials (Server-Side)
POCKETBASE_ADMIN_EMAIL=admin@akhtarserve.com
POCKETBASE_ADMIN_PASSWORD=your-admin-password

# PocketBase Version (for health check)
POCKETBASE_VERSION=0.22.1

# ==================== APP CONFIGURATION ====================

# App Configuration
APP_NAME="Akhtar Serve"
APP_URL=http://localhost:3000
NODE_ENV=development
