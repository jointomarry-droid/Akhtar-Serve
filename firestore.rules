rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isOrgMember(orgId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }
    
    function isOrgOwner(orgId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role == 'OWNER';
    }
    
    function isOrgAdmin(orgId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in ['OWNER', 'ADMIN'];
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if true; // Allow user creation during signup
      allow update: if isOwner(userId);
      allow delete: if false; // Don't allow user deletion
      
      // User subcollections
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
      
      match /apiKeys/{keyId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // Organizations collection
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if isAuthenticated();
      allow update: if isOrgAdmin(orgId);
      allow delete: if isOrgOwner(orgId);
      
      // Organization members
      match /members/{memberId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgAdmin(orgId);
      }
      
      // Products
      match /products/{productId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if isOrgAdmin(orgId);
        
        // Product variants
        match /variants/{variantId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId);
        }
        
        // Product media
        match /media/{mediaId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId);
        }
        
        // Product listings
        match /listings/{listingId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId);
        }
      }
      
      // Orders
      match /orders/{orderId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if false; // Don't delete orders
        
        // Order items
        match /items/{itemId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId);
        }
        
        // Order fulfillments
        match /fulfillments/{fulId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId);
        }
        
        // Order returns
        match /returns/{retId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId);
        }
      }
      
      // Integrations
      match /integrations/{intId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if isOrgAdmin(orgId);
        
        // Sync logs
        match /syncLogs/{logId} {
          allow read: if isOrgMember(orgId);
          allow create: if isOrgMember(orgId);
        }
      }
      
      // Inventory
      match /inventory/{itemId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId);
      }
      
      // Pricing rules
      match /pricingRules/{ruleId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if isOrgAdmin(orgId);
      }
      
      // Audit logs
      match /auditLogs/{logId} {
        allow read: if isOrgAdmin(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if false;
        allow delete: if false;
      }
      
      // Daily metrics
      match /dailyMetrics/{date} {
        allow read: if isOrgMember(orgId);
        allow write: if false; // Only written by Cloud Functions
      }
      
      // Notifications
      match /notifications/{notifId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId);
      }
      
      // Webhooks
      match /webhooks/{whId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgAdmin(orgId);
        allow update: if isOrgAdmin(orgId);
        allow delete: if isOrgAdmin(orgId);
      }
    }
  }
}
