{
  "name": "akhtar-serve",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:pocketbase": "concurrently \"npm run pocketbase:serve\" \"next dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "firebase:deploy": "firebase deploy",
    "firebase:emulators": "firebase emulators:start",
    "pocketbase:serve": "./pb/pocketbase.exe serve --dir ./pb/data --http=127.0.0.1:8090",
    "pocketbase:setup": "tsx scripts/setup-pocketbase-collections.ts",
    "pocketbase:seed": "tsx scripts/seed-pocketbase-data.ts",
    "pocketbase:test": "tsx scripts/test-pocketbase-connection.ts",
    "pocketbase:migrate": "tsx scripts/migrate-from-firestore.ts",
    "pocketbase:migrate:dry": "tsx scripts/migrate-from-firestore.ts --dry-run",
    "pocketbase:backup:create": "tsx scripts/pocketbase-backup.ts --create",
    "pocketbase:backup:list": "tsx scripts/pocketbase-backup.ts --list",
    "pocketbase:backup:restore": "tsx scripts/pocketbase-backup.ts --restore",
    "pocketbase:backup:cleanup": "tsx scripts/pocketbase-backup.ts --cleanup",
    "pocketbase:health": "curl http://localhost:8090/api/health",
    "pocketbase:debug": "tsx -e \"import { debugPocketBase } from './lib/pocketbase-errors'; debugPocketBase().then(console.log)\"",
    "prepare": "husky install"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@tanstack/react-query": "^5.59.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^11.0.1",
    "firebase-admin": "^12.6.0",
    "lucide-react": "^0.453.0",
    "next": "14.2.18",
    "next-themes": "^0.4.3",
    "pocketbase": "^0.22.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.2",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "husky": "^9.1.6",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.2.10",
    "playwright": "^1.49.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
